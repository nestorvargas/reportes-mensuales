# Example environment file for Complemento360
# Do NOT store real credentials here. Copy to `.env` and fill secrets locally.

DATABASE_URL=postgresql+asyncpg://c360:REPLACE_ME@localhost:5433/complemento360
SECRET_KEY=replace-with-secure-key
APP_USER=your_user
APP_PASSWORD=your_password

# SMTP (outgoing mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@example.com

# Other settings
# DEBUG=false
